COMPOSE_PROJECT_NAME=portfolio

FRONTEND_PORT=4321
BACKEND_PORT=8000

BUILD_VERSION=development
COMMIT_SHA=development
BUILT_AT=development

PUBLIC_OPENPANEL_CLIENT_ID=
PUBLIC_OPENPANEL_API_URL=
PUBLIC_OPENPANEL_SCRIPT_URL=
PUBLIC_API_BASE_URL=

API_APP_NAME=Portfolio API
API_LOG_LEVEL=DEBUG
API_CORS_ORIGINS=["https://noel.fyi"]
API_LLM_BASE_URL=https://llm.noel.fyi
API_EMBEDDINGS_BASE_URL=https://embeddings.noel.fyi
API_RERANKING_BASE_URL=https://reranking.noel.fyi
API_LLM_BEARER_TOKEN=
