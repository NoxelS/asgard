API_LLM_MODEL=SmolLM2-360M-Instruct-Q8_0
API_CHAT_COMPLETIONS_PATH=/v1/chat/completions
API_CHAT_MAX_TOKENS=256
API_REDIS_URL=redis://redis:6379
API_REDIS_INDEX_NAME=portfolio_content
API_CONTENT_ROOT=/app/content
API_INSTRUCTIONS_ROOT=/app/instructions
API_BOOTSTRAP_CHUNK_SIZE=1200
API_BOOTSTRAP_CHUNK_OVERLAP=200
API_NTFY_ENABLED=false
API_NTFY_TOPIC=
