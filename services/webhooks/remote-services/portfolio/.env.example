API_EMBEDDINGS_PATH=/v1/embeddings
API_EMBEDDING_PREFIX=query: 
API_EMBEDDING_PASSAGE_PREFIX=passage: 
API_RERANKER_MODEL=bge-reranker-v2-m3-Q8_0
