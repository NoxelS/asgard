{
	admin off
	auto_https disable_redirects
}

http:// {
	redir https://{host}{uri} 308
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
	}
}

noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers
	reverse_proxy portfolio-frontend-1:4321
}

api.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers
	reverse_proxy portfolio-backend-1:8000
}

ntfy.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers
	reverse_proxy ntfy:80
}

hooks.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers
	reverse_proxy webhooks:9000
}

uptime.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers
	reverse_proxy uptime-kuma:3001
}

llm.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers

	@authorized header Authorization "Bearer {$LLM_BEARER_TOKEN}"
	handle @authorized {
		reverse_proxy llama-llm:8080
	}

	handle {
		header WWW-Authenticate "Bearer"
		respond "Unauthorized" 401
	}
}

embeddings.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers

	@authorized header Authorization "Bearer {$LLM_BEARER_TOKEN}"
	handle @authorized {
		reverse_proxy llama-embeddings:8080
	}

	handle {
		header WWW-Authenticate "Bearer"
		respond "Unauthorized" 401
	}
}

reranking.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers

	@authorized header Authorization "Bearer {$LLM_BEARER_TOKEN}"
	handle @authorized {
		reverse_proxy llama-reranking:8080
	}

	handle {
		header WWW-Authenticate "Bearer"
		respond "Unauthorized" 401
	}
}

analytics.noel.fyi {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers

	handle_path /api* {
		reverse_proxy openpanel-api:3000
	}

	reverse_proxy openpanel-dashboard:3000
}

{$CADDY_SITE_ADDRESSES} {
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	import security_headers

	respond "No public service is configured on this origin yet." 404
}
